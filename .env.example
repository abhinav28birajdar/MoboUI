# ==========================================
# MOBOUI - Production Environment Template
# ==========================================
# IMPORTANT: Copy this file to .env.local for development
# DO NOT commit .env.local - it contains sensitive secrets!
# ==========================================

# ==========================================
# Application Configuration
# ==========================================

# Application environment (development, production, staging)
NODE_ENV=development

# Application public URL (used for OAuth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API base URL
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ==========================================
# Supabase Configuration (REQUIRED)
# ==========================================
# Get these from: https://supabase.com/dashboard -> Project Settings -> API

# Supabase Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key (public, safe for browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (SECRET - server-only!)
# KEEP THIS SAFE - DO NOT EXPOSE IN FRONTEND
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ==========================================
# Storage Configuration
# ==========================================

# Supabase Storage Buckets
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET_COMPONENTS=components
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET_AVATARS=avatars
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET_PROJECTS=projects

# Maximum upload file size (bytes, default: 5MB)
NEXT_PUBLIC_MAX_FILE_SIZE=5242880

# ==========================================
# Authentication & OAuth Providers
# ==========================================

# GitHub OAuth (Configure in Supabase Auth > Providers)
# GITHUB_CLIENT_ID=your-github-id
# GITHUB_CLIENT_SECRET=your-github-secret

# Google OAuth (Configure in Supabase Auth > Providers)
# GOOGLE_CLIENT_ID=your-google-id
# GOOGLE_CLIENT_SECRET=your-google-secret

# ==========================================
# Email Service (Optional)
# ==========================================

# For transactional emails (Resend, SendGrid, etc.)
# RESEND_API_KEY=your-resend-api-key
# SENDGRID_API_KEY=your-sendgrid-api-key

# Email sender address
# NEXT_PUBLIC_EMAIL_FROM=noreply@moboui.com

# ==========================================
# Database Configuration
# ==========================================

# Direct PostgreSQL connection (if needed)
# DATABASE_URL=postgresql://user:password@host:5432/moboui

# ==========================================
# Feature Flags
# ==========================================

# Enable/disable features
NEXT_PUBLIC_ENABLE_PLAYGROUND=true
NEXT_PUBLIC_ENABLE_SUBMISSIONS=true
NEXT_PUBLIC_ENABLE_MARKETPLACE=true
NEXT_PUBLIC_ENABLE_ADMIN=true

# ==========================================
# Analytics & Monitoring
# ==========================================

# Sentry (error tracking)
# SENTRY_AUTH_TOKEN=your-sentry-token
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXX

# PostHog (product analytics)
# NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key

# ==========================================
# Security & Performance
# ==========================================

# CORS allowed origins (comma-separated)
NEXT_PUBLIC_CORS_ORIGINS=http://localhost:3000

# JWT secret (if using custom JWT)
# JWT_SECRET=your-secret-key

# Rate limiting (requests per minute)
# RATE_LIMIT_REQUESTS=60

# Content Security Policy settings
# NEXT_PUBLIC_CSP_ENABLED=true

# ==========================================
# Payment Processing (Optional)
# ==========================================

# Stripe
# NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ==========================================
# CDN & Performance
# ==========================================

# Content Delivery Network (optional)
# NEXT_PUBLIC_CDN_URL=https://cdn.example.com

# Image optimization
NEXT_PUBLIC_IMAGE_OPTIMIZATION=true

# ==========================================
# Development Settings
# ==========================================

# Debug mode
DEBUG=false

# Development features
NEXT_PUBLIC_DEV_MODE=false

# Database seeding
NEXT_PUBLIC_SEED_DATABASE=false

# ==========================================
# Deployment Platforms
# ==========================================

# Vercel
# VERCEL_ENV=production
# VERCEL_URL=your-app.vercel.app

# Railway, Render, etc.
# For deployment, set environment variables in your platform's dashboard

# ==========================================
# IMPORTANT NOTES
# ==========================================
#
# 1. NEXT_PUBLIC_* variables:
#    - Exposed to browser
#    - Safe for non-sensitive config only
#    - Don't put API keys or secrets here
#
# 2. Variables WITHOUT NEXT_PUBLIC_:
#    - Server-only
#    - Safe for secrets and API keys
#    - Won't be exposed to client
#
# 3. For Local Development:
#    - Copy this file: cp .env.example .env.local
#    - Fill in your actual values
#    - NEVER commit .env.local
#
# 4. For Production:
#    - Use your hosting platform's environment settings
#    - Vercel: Project Settings > Environment Variables
#    - Railway: Variables menu
#    - AWS Amplify: App Settings > Environment Variables
#
# 5. Keep Secrets Safe:
#    - Rotate keys regularly
#    - Use different keys per environment
#    - Monitor access logs
#    - Use secret management tools
#
# ==========================================
