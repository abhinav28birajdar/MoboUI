# ========================================
# MOBOUI Production-Grade .gitignore
# ========================================

# ========================================
# Dependencies & Package Managers
# ========================================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.yarn/install-state.gz

# pnpm (alternative package manager)
pnpm-lock.yaml
.pnpm-store/

# npm (alternative package manager)
npm-debug.log*
npm-error.log*
package-lock.json

# yarn
yarn-error.log*
yarn-debug.log*
.yarn.lock

# ========================================
# Build Output & Distribution
# ========================================
/.next/
/out/
/dist/
/build/
.next

# Next.js specific
.next/
out/

# TypeScript
*.tsbuildinfo
next-env.d.ts
**/*.d.ts

# ========================================
# Testing & Coverage
# ========================================
/coverage/
.nyc_output/
/test-results/
jest.results.json
coverage.txt

# Vitest
.vitest/

# ========================================
# Environment & Secrets
# ========================================
# IMPORTANT: Never commit environment files with secrets!
.env
.env.local
.env.*.local
.env.production
.env.production.local
.env.development
.env.development.local
.env.test
.env.test.local

# .env.example is OK to commit - it shows required variables WITHOUT values

# ========================================
# IDE & Editor Configuration
# ========================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.AppleDouble
.LSOverride
.env.swp
.vimrc
.editorconfig

# VS Code
.vscode/settings.json
.vscode/launch.json
.vscode/extensions.json
*.code-workspace

# WebStorm / IntelliJ
.idea/
*.iml
*.iws
*.ipr
out/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[p-z]
Session.vim
.netrwhist

# ========================================
# Runtime & Execution
# ========================================
# OS specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# Process files
*.pid
*.pid.lock

# Logs
logs/
*.log
lerna-debug.log*

# ========================================
# Temporary & Cache Files
# ========================================
# Node cache
.cache/
.eslintcache
.stylelintcache

# Temporary files
*.tmp
*.temp
tmp/
temp/

# Bundle analyzer
.webpack-stats.json

# ========================================
# Database & Storage
# ========================================
# Local Supabase instance
# supabase/ - Keep this for schema files
# But ignore local supabase data
.supabase/

# Database files (except schema files)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
*.sql.bak
*.sql.gz
!supabase-schema.sql
!supabase/schema.sql

# ========================================
# Docker & Containerization
# ========================================
# Docker build artifacts
docker-compose.override.yml
.dockerignore

# Docker local data (development)
/data/
/data/postgres/
/data/redis/
/data/supabase/

# Docker volume state files
moboui-postgres-data/
moboui-redis-data/
moboui-supabase-data/

# ========================================
# Build Artifacts & Distribution
# ========================================
dist/
*.tgz
build/

# ========================================
# Development Tools
# ========================================
# Vercel
.vercel

# Error files
error.log
*.error

# Crash dumps
core
core.*

# ========================================
# IDE Extensions & Plugins
# ========================================
# VS Code
.vscode/extensions.json
.vscode-test/
.history/

# JetBrains additional
*.jks
*.keystore

# ========================================
# Security & Secrets
# ========================================
# SSH keys
*.pem
*.pub
*.key
*.cer
*.crt
*.p12
*.keystore
*_key
*_secret
*_token

# ========================================
# Backup & Archive Files
# ========================================
*.backup
*.bak
*~
*.orig
*.rej

# ========================================
# OS Specific Files
# ========================================
# Windows
*.lnk
$RECYCLE.BIN/
ehthumbs.db
desktop.ini
Thumbs.db

# macOS
._*
.Spotlight-V100
.Trashes

# Linux
.Xauthority
.bash_history
.bashrc
.profile
.sh_history
.zsh_history

# ========================================
# Dependency Lock Files (optional - uncomment if needed)
# ========================================
# package-lock.json
# pnpm-lock.yaml
# yarn.lock

# ========================================
# Project Specific
# ========================================
# Don't commit local configuration overrides
.env.local
.env.local.example

# Don't commit uploaded files (use CDN instead)
/uploads/
/public/uploads/

# Don't commit media files (use cloud storage)
/media/
/videos/
/images/

# Custom theme files (if generating locally)
/generated-themes/

# Local development files
.local/
.dev/
/replace-theme.js
/.eslintrc.cjs

# CI/CD logs
.github/workflows/*.log

# Performance & Profiling
*.profile
*.prof
*.trace

# ========================================
# IMPORTANT: Keep these files (!)
# ========================================
!.env.example
!.gitkeep
!package.json
!tsconfig.json
!next.config.ts
!database/master.sql
